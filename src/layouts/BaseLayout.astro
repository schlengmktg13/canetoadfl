---
// src/layouts/BaseLayout.astro
// Every page uses this layout. Pass title, description, and canonical as props.

const { title, description, canonical, schema } = Astro.props;
const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).toString();
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />

  <!-- Schema: Local Business (override per page as needed) -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "CaneToadFL",
      "description": "South Florida cane toad and bufo toad removal service directory",
      "areaServed": "South Florida",
      "url": "https://canetoadfl.com"
    }
  </script>
  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --green: #1a6b3a;
      --green-dark: #124d2a;
      --green-light: #e8f5ed;
      --orange: #e06b1a;
      --text: #1a1a1a;
      --text-muted: #555;
      --border: #ddd;
      --max-width: 960px;
      --reading-width: 640px;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      font-size: 17px;
      line-height: 1.7;
      color: var(--text);
      background: #fff;
    }

    a { color: var(--green); text-decoration: none; }
    a:hover { text-decoration: underline; }

    /* NAV */
    header {
      background: var(--green-dark);
      padding: 0 1.5rem;
    }
    nav {
      max-width: var(--max-width);
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 60px;
    }
    .nav-logo {
      color: #fff;
      font-size: 1.2rem;
      font-weight: 700;
      letter-spacing: -0.02em;
    }
    .nav-links { display: flex; gap: 1.5rem; list-style: none; }
    .nav-links a { color: rgba(255,255,255,0.85); font-size: 0.95rem; }
    .nav-links a:hover { color: #fff; text-decoration: none; }

    /* MAIN */
    main {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 2.5rem 1.5rem 4rem;
    }

    /* CTA BUTTON */
    .btn {
      display: inline-block;
      background: var(--orange);
      color: #fff;
      font-weight: 700;
      font-size: 1.05rem;
      padding: 0.85rem 2rem;
      border-radius: 6px;
      border: none;
      cursor: pointer;
      text-decoration: none;
    }
    .btn:hover { background: #c45c14; text-decoration: none; }
    .btn-lg { font-size: 1.2rem; padding: 1rem 2.5rem; }

    /* HERO */
    .hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr);
      gap: 2rem;
      align-items: center;
      background: var(--green-light);
      border-left: 5px solid var(--green);
      padding: 2.5rem 2rem;
      border-radius: 8px;
      margin-bottom: 2.5rem;
    }
    .hero-media .content-image {
      width: 100%;
      max-height: min(360px, 45vh);
      object-fit: cover;
      border-radius: 10px;
    }
    .hero-copy h1 {
      font-size: 2.2rem;
      line-height: 1.25;
      color: var(--green-dark);
      margin-bottom: 1rem;
    }
    .hero-copy p {
      font-size: 1.15rem;
      color: var(--text-muted);
      max-width: 640px;
      margin-bottom: 1.5rem;
    }

    /* URGENCY BANNER */
    .urgency {
      background: #fff3cd;
      border: 1px solid #ffc107;
      border-radius: 6px;
      padding: 1rem 1.25rem;
      margin-bottom: 2rem;
      font-size: 0.95rem;
    }
    .urgency strong { color: #856404; }

    /* LEAD FORM */
    .lead-form-wrap {
      background: var(--green-dark);
      color: #fff;
      border-radius: 10px;
      padding: 2rem;
      margin: 2.5rem 0;
    }
    .lead-form-wrap h2 { font-size: 1.5rem; margin-bottom: 0.5rem; }
    .lead-form-wrap p { color: rgba(255,255,255,0.8); margin-bottom: 1.5rem; font-size: 0.95rem; }
    .lead-form-wrap iframe {
      display: block;
      width: 100%;
      max-width: 560px;
      margin: 0 auto;
      border: 0;
    }
    /* CONTENT */
    .content h2 {
      font-size: 1.6rem;
      color: var(--green-dark);
      margin: 2rem 0 0.75rem;
      border-bottom: 2px solid var(--green-light);
      padding-bottom: 0.4rem;
    }
    .content h3 { font-size: 1.2rem; color: var(--text); margin: 1.5rem 0 0.5rem; }
    .content p { margin-bottom: 1rem; }
    .content ul, .content ol { padding-left: 1.5rem; margin-bottom: 1rem; }
    .content li { margin-bottom: 0.4rem; }
    .content > p,
    .content > ul,
    .content > ol,
    .content > h2,
    .content > h3,
    .content > .faq,
    .content > .toc-card,
    .content > .content-card,
    .content > figure.content-figure {
      max-width: var(--reading-width);
      margin-left: 0;
      margin-right: auto;
    }

    /* Raster images (astro:assets + plain <img> in article body) */
    .content .content-image,
    .content img {
      max-width: 100%;
      height: auto;
      display: block;
      border-radius: 8px;
    }
    .content figure.content-figure {
      margin: 1.5rem 0;
    }
    .content figure.content-figure figcaption {
      font-size: 0.85rem;
      color: var(--text-muted);
      margin-top: 0.5rem;
      line-height: 1.4;
    }

    /* CONTENT UTILITIES */
    .content-card {
      background: var(--green-light);
      border-radius: 8px;
      padding: 1.25rem 1.5rem;
      margin: 1.5rem 0;
    }
    .toc-card {
      background: var(--green-light);
      border-radius: 8px;
      padding: 1.5rem 2rem;
      margin-bottom: 2rem;
    }
    .toc-title {
      display: block;
      margin-bottom: 0.75rem;
      color: var(--green-dark);
    }
    .toc-list {
      margin: 0;
      padding-left: 1.25rem;
    }

    /* GEO GRID */
    .geo-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 1rem;
      margin: 1.5rem 0;
    }
    .geo-card {
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1rem;
      text-align: center;
    }
    .geo-card a { font-weight: 600; }
    .geo-card p { font-size: 0.85rem; color: var(--text-muted); margin: 0.25rem 0 0; }

    /* FAQ */
    .faq { margin: 2rem 0; }
    .faq details {
      border-bottom: 1px solid var(--border);
      padding: 1rem 0;
    }
    .faq summary {
      font-weight: 600;
      cursor: pointer;
      list-style: none;
      display: flex;
      justify-content: space-between;
    }
    .faq summary::after { content: '+'; font-size: 1.2rem; color: var(--green); }
    .faq details[open] summary::after { content: '−'; }
    .faq details p { margin-top: 0.75rem; color: var(--text-muted); }

    /* FOOTER */
    footer {
      background: var(--green-dark);
      color: rgba(255,255,255,0.7);
      padding: 2rem 1.5rem;
      font-size: 0.9rem;
      margin-top: 4rem;
    }
    .footer-inner {
      max-width: var(--max-width);
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
    }
    footer a { color: rgba(255,255,255,0.7); }
    footer a:hover { color: #fff; }

    @media (max-width: 720px) {
      .hero {
        grid-template-columns: 1fr;
      }
      .hero-media .content-image {
        max-height: 220px;
      }
    }
    @media (max-width: 640px) {
      .hero-copy h1 { font-size: 1.6rem; }
      .nav-links { display: none; }
    }
  </style>
</head>
<body>

<header>
  <nav>
    <a href="/" class="nav-logo">🐸 CaneToadFL</a>
    <ul class="nav-links">
      <li><a href="/cane-toad-removal/">Removal Services</a></li>
      <li><a href="/cane-toad-florida/">About Cane Toads</a></li>
      <li><a href="/cane-toad-removal-cost/">Pricing</a></li>
      <li><a href="/cane-toad-dog-poisoning/">Dog Safety</a></li>
      <li><a href="/providers/">For Providers</a></li>
    </ul>
  </nav>
</header>

<main>
  <slot />
</main>

<footer>
  <div class="footer-inner">
    <div>
      <strong style="color:#fff">CaneToadFL</strong><br/>
      Connecting South Florida homeowners with<br/>licensed cane toad removal professionals.
    </div>
    <div>
      <a href="/cane-toad-removal/">Removal Services</a> ·
      <a href="/cane-toad-florida/">About Cane Toads</a> ·
      <a href="/providers/">Provider Sign-Up</a> ·
      <a href="/privacy-policy/">Privacy Policy</a>
    </div>
  </div>
</footer>

<script async src="https://tally.so/widgets/embed.js"></script>
</body>
</html>
